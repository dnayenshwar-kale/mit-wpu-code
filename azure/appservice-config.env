# Azure App Service Configuration
# This file contains environment variables for Azure App Service

# Application Settings
SPRING_PROFILES_ACTIVE=prod,azure

# Database Configuration (Azure Database for MySQL)
AZURE_DB_URL=jdbc:mysql://your-mysql-server.mysql.database.azure.com:3306/your-database
AZURE_DB_USERNAME=your-db-username@your-mysql-server
AZURE_DB_PASSWORD=your-db-password

# Azure Application Insights
APPINSIGHTS_INSTRUMENTATIONKEY=your-appinsights-key

# Azure Key Vault (if using)
AZURE_KEYVAULT_URI=https://your-keyvault.vault.azure.net/
AZURE_CLIENT_ID=your-client-id
AZURE_CLIENT_SECRET=your-client-secret
AZURE_TENANT_ID=your-tenant-id

# CORS Configuration
ALLOWED_ORIGINS=https://your-frontend-domain.com

# Server Configuration
PORT=8080

# Logging
LOGGING_LEVEL_COM_EXAMPLE_DEMO=INFO